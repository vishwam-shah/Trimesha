# MongoDB connection string
MONGO_URI=

# NextAuth — generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=
# The canonical URL of your deployment (e.g. https://your-app.vercel.app)
NEXTAUTH_URL=

# Resend (https://resend.com) — used for job-application emails
RESEND_API_KEY=
# Must be a verified sender address / domain in your Resend account
RESEND_FROM_EMAIL=careers@notifications.trimesha.com
